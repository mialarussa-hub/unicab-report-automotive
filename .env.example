# =============================================================================
# UNICAB Report Automotive — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# =============================================================================

# --- Database ---
POSTGRES_USER=unicab
POSTGRES_PASSWORD=changeme
POSTGRES_DB=unicab
DATABASE_URL=postgresql+asyncpg://unicab:changeme@db:5432/unicab

# --- FastAPI ---
SECRET_KEY=changeme-generate-a-real-secret-key
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# --- n8n ---
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme
N8N_HOST=unicab.automica.it
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=https://unicab.automica.it/n8n/

# --- AI ---
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- External APIs ---
YOUTUBE_API_KEY=
FACEBOOK_ADS_TOKEN=

# --- Domain ---
DOMAIN=unicab.automica.it

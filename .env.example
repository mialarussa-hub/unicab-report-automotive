# =============================================================================
# UNICAB Report Automotive — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# =============================================================================

# --- Database ---
POSTGRES_USER=unicab
POSTGRES_PASSWORD=changeme
POSTGRES_DB=unicab
DATABASE_URL=postgresql+asyncpg://unicab:changeme@db:5432/unicab

# --- FastAPI ---
SECRET_KEY=changeme-generate-a-real-secret-key
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# --- n8n ---
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme
N8N_HOST=unicab.automica.it
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=https://unicab.automica.it/n8n/

# --- AI ---
# Anthropic Claude — sentiment + minireport L2 + aggregazione L1
ANTHROPIC_API_KEY=sk-ant-xxxxx
# OpenAI — trascrizione audio YouTube editoriale via Whisper API (L2)
OPENAI_API_KEY=sk-proj-xxxxx

# --- External APIs ---
# Firecrawl — scraping news 2-step (search → scrape)
FIRECRAWL_API_KEY=fc-xxxxx
# YouTube Data API v3 — commenti, ricerca canali, metadati
YOUTUBE_API_KEY=
# Perplexity Sonar Pro — L1 Strato B (web ufficiale esteso)
PERPLEXITY_API_KEY=pplx-xxxxx
# Facebook Ads Library — L4 (quando attivo)
FACEBOOK_ADS_TOKEN=

# --- Proxy ---
# Webshare residential proxy — yt-dlp download audio (bypass YouTube datacenter ban)
# Formato: http://USERNAME:PASSWORD@HOST:PORT
WEBSHARE_PROXY_URL=

# --- Domain ---
DOMAIN=unicab.automica.it

# Environment
.env
.env.local
.env.production

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Docker
docker-compose.override.yml

# Nginx SSL certs (managed by certbot on server)
nginx/ssl/*.pem
nginx/ssl/*.key

# n8n credentials (never commit real credentials)
n8n/credentials/*.json
!n8n/credentials/.gitkeep

# Database
*.db
*.sqlite3

# Logs
*.log
logs/

# Coverage
.coverage
htmlcov/
.pytest_cache/

# Alembic
backend/alembic/versions/__pycache__/

# Secret files — never commit
**/Credentials*
**/credentials*
!**/credentials/.gitkeep
*.secret

.claude/

# PM private sources (call notes, mails, internal docs — never commit)
pm/sources/
